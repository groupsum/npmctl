{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://npmctl.com/schemas/repository.v1.schema.json",
  "title": "npmctl Repository v1",
  "type": "object",
  "required": ["apiVersion", "kind", "schemaVersion", "metadata", "spec"],
  "properties": {
    "apiVersion": {"const": "npmctl.com/v1"}, "kind": {"const": "NpmctlRepository"},
    "schemaVersion": {"const": 1},
    "metadata": {"type": "object", "required": ["name"], "properties": {"name": {"type": "string", "minLength": 1}}},
    "spec": {"type": "object", "required": ["owners", "environments"], "properties": {
      "owners": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
      "environments": {"type": "object", "minProperties": 1}, "domains": {"type": "array"}
    }}
  },
  "additionalProperties": false
}
