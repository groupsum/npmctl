{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/npmctl/schemas/desired-state.v1.schema.json",
  "title": "npmctl desired-state v1",
  "type": "object",
  "required": ["apiVersion", "schemaVersion"],
  "properties": {
    "apiVersion": {"const": "npmctl.io/v1"},
    "schemaVersion": {"const": 1},
    "certificates": {"type": "array", "items": {"$ref": "#/$defs/certificate"}},
    "access_lists": {"type": "array", "items": {"$ref": "#/$defs/accessList"}},
    "proxy_hosts": {"type": "array", "items": {"$ref": "#/$defs/proxyHost"}}
  },
  "additionalProperties": true,
  "$defs": {
    "meta": {
      "type": "object",
      "required": ["managed_by", "owner", "resource_id"],
      "properties": {
        "managed_by": {"const": "npmctl"},
        "owner": {"type": "string", "minLength": 1},
        "resource_id": {"type": "string", "minLength": 1}
      },
      "additionalProperties": true
    },
    "certificate": {
      "type": "object",
      "required": ["name", "domain_names", "meta"],
      "properties": {
        "name": {"type": "string"},
        "domain_names": {"type": "array", "items": {"type": "string"}},
        "certificate_type": {"type": "string"},
        "api_payload": {"type": "object"},
        "meta": {"$ref": "#/$defs/meta"}
      }
    },
    "accessList": {
      "type": "object",
      "required": ["name", "meta"],
      "properties": {
        "name": {"type": "string"},
        "api_payload": {"type": "object"},
        "meta": {"$ref": "#/$defs/meta"}
      }
    },
    "proxyHost": {
      "type": "object",
      "required": ["domain_names", "forward_host", "forward_port", "meta"],
      "properties": {
        "domain_names": {"type": "array", "items": {"type": "string"}},
        "forward_host": {"type": "string"},
        "forward_port": {"type": "integer", "minimum": 1, "maximum": 65535},
        "forward_scheme": {"enum": ["http", "https"]},
        "certificate_ref": {"type": "string"},
        "certificate_id": {"type": "integer"},
        "access_list_ref": {"type": "string"},
        "access_list_id": {"type": "integer"},
        "meta": {"$ref": "#/$defs/meta"}
      }
    }
  }
}
